{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Blocker",
  "version": "0.1.0",
  "identifier": "com.aslonkhamidov.ddetox",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Blocker",
        "width": 820,
        "height": 680,
        "minWidth": 520,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Controller GUI for the blocker daemon.",
    "longDescription": "Unprivileged desktop GUI to edit blocklists and run focus sessions. Enforcement and authoritative state live in the privileged blocker daemon; this app is a view/controller over it.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "entitlements": null
    }
  }
}
